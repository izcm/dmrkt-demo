# server-side variables only – NEXT_PUBLIC vars passed as build args by docker-compose

# Server components run inside the container and must use the internal
# Docker network address (e.g. http://indexer:5000) to reach the indexer.
# 
# Browser fetches can't reach the internal Docker address, only localhost.
#
# So build arg NEXT_PUBLIC_INDEXER_API is for client components
# while INDEXER_API is for server components
INDEXER_API=http://indexer:5000/api